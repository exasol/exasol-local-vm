# Pinned reference to the upstream Exasol Nano .run release.
#
# How to bump:
#   1. Update NANO_RELEASE_TAG and the two URLs.
#   2. Clear NANO_AARCH64_SHA and NANO_X86_64_SHA (leave them empty).
#   3. Run `./build.sh <arch>` — it captures the SHAs automatically on the
#      first build with empty values, then verifies them on every rebuild.
#   4. Review the diff to this file and commit it together with any
#      Containerfile / entrypoint changes.

NANO_RELEASE_TAG=2026.04.09

NANO_AARCH64_URL=https://github.com/exasol-labs/exasol-nano/releases/download/2026.04.09/exasol-nano-db-2026.1.0-dev.1-aarch64.run
NANO_AARCH64_SHA=9bab229e0ece1ebdcb04c6f5b2180911702f21f8f984552b6b37d68afaeb6746

NANO_X86_64_URL=https://github.com/exasol-labs/exasol-nano/releases/download/2026.04.09/exasol-nano-db-2026.1.0-dev.1-x86_64.run
NANO_X86_64_SHA=ca3c6501a4cffe1e850819b888a4d81d3382cfe330caf48ee632b95ed251cc8b
