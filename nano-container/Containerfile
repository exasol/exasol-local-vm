# Multi-stage to keep the .run out of any shipped layer (nested podman-load
# in the VM build can't always read large files in a layer diff).
# Alpine works because the AppDir bundles its own glibc + linker.

FROM alpine:3.20 AS extract
# xz: the .run is Makeself + xz-compressed. bash: needed by .run's scripts.
RUN apk add --no-cache bash xz
COPY nano.run /tmp/exasol-db.run
RUN chmod +x /tmp/exasol-db.run \
 && /tmp/exasol-db.run --noexec --target /opt/exasol-nano \
 && rm /tmp/exasol-db.run


FROM alpine:3.20
RUN apk add --no-cache bash
COPY --from=extract /opt/exasol-nano /opt/exasol-nano
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV EXANANO_EXADIR=/var/lib/exanano
EXPOSE 8563 8443
ENTRYPOINT ["/entrypoint.sh"]
